# ─────────────────────────────────────────────────────────────────────
# PyroSense Simulator — variables de entorno
# Copia este archivo a `.env` y rellena los valores reales.
# `.env` está en .gitignore: los valores reales NUNCA se versionan.
# ─────────────────────────────────────────────────────────────────────

# Endpoint de AWS IoT Core (ATS). Obtenerlo con:
#   aws iot describe-endpoint --endpoint-type iot:Data-ATS
PYROSENSE_IOT_ENDPOINT=xxxxxxxxxxxxxx-ats.iot.us-east-1.amazonaws.com

# Rutas a los certificados X.509 del dispositivo (directorio certs/ ignorado por git)
PYROSENSE_CERT_PATH=certs/device.pem.crt
PYROSENSE_PRIVATE_KEY_PATH=certs/private.pem.key
PYROSENSE_ROOT_CA_PATH=certs/AmazonRootCA1.pem

# Prefijo base de los topics MQTT. El topic final es:
#   {PYROSENSE_TOPIC_BASE}/{PYROSENSE_ENV}/telemetry/{device_id}
PYROSENSE_TOPIC_BASE=pyrosense

# Entorno de despliegue objetivo: dev | staging | prod
PYROSENSE_ENV=dev
